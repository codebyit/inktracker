# App
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (compose all-in-one default)
DATABASE_URL=postgresql+psycopg://inktrack:inktrack@postgres:5432/inktrack

# Cache
REDIS_URL=redis://redis:6379/0

# Optional admin auth (opt-in). When set, destructive endpoints
# (/settings/backup, /settings/restore, /settings/reset) require the
# header `X-Admin-Token: <value>`. Leave empty/unset to keep the LAN-only
# default (no auth) — safe for private networks behind a VPN/tunnel.
# Use a long random string (e.g., `openssl rand -hex 32`).
# ADMIN_API_TOKEN=

# Branding (public defaults shown; override to rebrand without code changes)
APP_NAME=InkTrack
APP_OWNER=

# Features
# Set to true to enable the multi-craft wizard (multiple craft faces per project).
# Default off; existing single-craft projects are unaffected.
MULTI_CRAFT_ENABLED=false

# Optional image override
APP_IMAGE=ghcr.io/codebyit/inktracker:latest
