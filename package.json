{
  "name": "inktracker",
  "version": "0.13.1",
  "description": "UV Print Cost Tracker — Self-hosted production and costing tracker",
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./static/app.css --minify",
    "dev:css": "tailwindcss -i ./tailwind.input.css -o ./static/app.css --watch",
    "vendor:jsqr": "node -e \"const fs=require('fs');fs.mkdirSync('static/vendor',{recursive:true});fs.copyFileSync('node_modules/jsqr/dist/jsQR.js','static/vendor/jsqr.js')\"",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "jsqr": "^1.4.0",
    "tailwindcss": "^4.3.1"
  }
}
